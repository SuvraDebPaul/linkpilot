
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth v4 required tables) ────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?

  accounts      Account[]
  sessions      Session[]
  workspaces    WorkspaceMember[]
  links         Link[]
  campaigns     Campaign[]
  customDomains CustomDomain[]
  clientAccesses ClientAccess[]

  // Stripe billing
  stripeCustomerId       String?  @unique
  stripeSubscriptionId   String?  @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  lifetimeAccess         Boolean  @default(false)

  // Lifetime usage counters — never decrease on delete
  totalLinksCreated     Int @default(0)
  totalCampaignsCreated Int @default(0)

  // Onboarding
  onboardingCompleted Boolean @default(false)

  // True only for accounts created via "Create account manually" on the
  // Organization page — these exist solely for that one workspace, so removing
  // the member can safely delete the whole account instead of just unlinking it.
  createdAsWorkspaceMember Boolean @default(false)

  // True only for the seeded public-demo account (and its seeded teammates).
  // Anyone can sign in with these shared credentials, so every redirect
  // destination they set is forced to a safe fixed URL — see
  // server/services/demo-guard.service.ts — instead of trusting arbitrary
  // input, which would otherwise make LinkPilot an open redirector.
  isDemoAccount Boolean @default(false)

  // Platform owner/operator — grants access to /admin and everything in it.
  // Deliberately a single flag (not a role enum) since there's exactly one
  // admin tier for now; see AdminAuditLog for the accountability trail every
  // admin action must leave behind.
  isSuperAdmin Boolean @default(false)

  // Set by a super-admin to immediately block all access (ToS violations,
  // abuse, etc) without deleting the account or its data.
  suspended   Boolean   @default(false)
  suspendedAt DateTime?

  // Preferences
  theme                    String    @default("auto") // "light" | "dark" | "auto"
  monthlyReportEnabled     Boolean   @default(false)
  monthlyReportLastSentAt  DateTime?

  // Security
  sessionVersion Int @default(0) // bumped to invalidate all existing JWTs
  loginEvents    LoginEvent[]

  // Onboarding email sequence tracking
  onboardingDay1SentAt DateTime?
  onboardingDay3SentAt DateTime?
  onboardingDay7SentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Failed credentials-login attempts only — used to rate-limit brute-force
// attacks by email and by IP. Successful logins are tracked in LoginEvent.
model LoginAttempt {
  id         String   @id @default(cuid())
  identifier String // lowercased email being guessed
  ip         String
  createdAt  DateTime @default(now())

  @@index([identifier, createdAt])
  @@index([ip, createdAt])
}

// Failed password-protected-link unlock attempts — rate-limits brute force
// against a single link's password.
model UnlockAttempt {
  id        String   @id @default(cuid())
  slug      String
  ip        String
  createdAt DateTime @default(now())

  @@index([slug, ip, createdAt])
}

// One row per CSV import call — rate-limits repeated bulk imports, independent
// of how many rows each import contains.
model ImportAttempt {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model LoginEvent {
  id     String @id @default(cuid())
  userId String

  type    String // "credentials" | "google" | "registration"
  ip      String?
  country String?
  city    String?
  browser String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Workspaces ─────────────────────────────────────────────────────────────

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

model Workspace {
  id   String @id @default(cuid())
  name String
  slug String @unique

  // Report white-labelling (Starter/Pro)
  brandLogoUrl String?
  brandColor   String?
  hideBranding Boolean @default(false)

  // Default settings applied when creating new links
  slugStyle              String  @default("random") // "incremental" | "random" | "secure"
  slugCounter             Int     @default(0)
  defaultRedirectType    String  @default("302") // "301" | "302" | "307" | "308"
  defaultCloakingEnabled Boolean @default(false)

  // QR code defaults for new links (Starter/Pro only — free links stay
  // plain black/white). Independent of brandColor/brandLogoUrl above, which
  // only theme shared campaign reports, never the QR code itself.
  defaultQrFgColor String @default("#000000")
  defaultQrBgColor String @default("#ffffff")
  defaultQrEcLevel String @default("M") // "L" | "M" | "Q" | "H"

  members           WorkspaceMember[]
  links             Link[]
  campaigns         Campaign[]
  customDomains     CustomDomain[]
  clientAccesses    ClientAccess[]
  geoTemplates      GeoTemplate[]
  campaignTemplates CampaignTemplate[]
  auditLogs         WorkspaceAuditLog[]

  // Set by a super-admin to immediately block all member access (ToS
  // violations, abuse) without deleting the workspace or its data.
  suspended   Boolean   @default(false)
  suspendedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

// Human-readable trail of admin actions (role changes, removals, ownership
// transfers, etc). actorUserId is a plain reference (no FK) so the log
// entry survives even after the actor's account is later removed.
model WorkspaceAuditLog {
  id          String  @id @default(cuid())
  workspaceId String
  actorUserId String?
  message     String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([createdAt])
}

// Accountability trail for every action taken from the super-admin panel
// (/admin) — force logout, plan grants, suspensions, deletions, impersonation
// start/end, etc. actorUserId is a plain reference (no FK), matching
// WorkspaceAuditLog, so the trail survives even if the admin account is later
// removed. targetType + targetId identify what the action was performed on
// (e.g. "User" / user id, "Workspace" / workspace id) without a real FK,
// since the target may belong to any of several different models.
model AdminAuditLog {
  id          String  @id @default(cuid())
  actorUserId String?
  action      String // e.g. "user.force_logout", "user.impersonate_start"
  targetType  String? // e.g. "User", "Workspace"
  targetId    String?
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// One row per scheduled cron run (see the 5 routes under src/app/api/cron) —
// lets /admin/system/cron-jobs show whether each job is actually running on
// schedule instead of only finding out when someone notices missing emails.
model CronRunLog {
  id        String   @id @default(cuid())
  jobName   String
  status    String // "success" | "error"
  message   String?
  durationMs Int?
  createdAt DateTime @default(now())

  @@index([jobName, createdAt])
}

// One row per Stripe webhook event received — lets /admin/system/webhooks
// surface delivery/handling health (including payment failures) without
// having to cross-reference the Stripe dashboard.
model WebhookEventLog {
  id           String   @id @default(cuid())
  provider     String   @default("stripe")
  eventType    String
  status       String // "success" | "error"
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([status])
}

// Simple on/off switches an admin can flip without a deploy — e.g.
// maintenanceMode, signupsEnabled. Deliberately just a key/bool/description,
// no targeting rules or percentage rollouts, since this is an operator kill
// switch, not an experimentation platform.
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}

// Domains new links are not allowed to redirect to (phishing/spam/abuse) —
// enforced in link.service.ts alongside the existing validateSafeUrl check.
// createdBy is a plain reference (no FK), matching AdminAuditLog/WorkspaceAuditLog.
model BlockedDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  reason    String?
  createdBy String?
  createdAt DateTime @default(now())
}

// Freeform internal notes a super-admin leaves on a user or workspace —
// support-team context ("waiting on refund confirmation", "flagged for
// review") that isn't part of either record's own data. resolved doubles as
// a lightweight follow-up flag instead of a separate ticketing model.
// authorUserId is a plain reference (no FK), matching AdminAuditLog.
model AdminNote {
  id           String   @id @default(cuid())
  targetType   String // "User" | "Workspace"
  targetId     String
  authorUserId String?
  note         String
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([targetType, targetId])
}

// Simple string key/value config an admin can edit without a deploy — e.g.
// the site-wide announcement banner or the support contact email shown in
// the footer. Deliberately just strings (JSON-encode if a value needs
// structure), same spirit as FeatureFlag but for values instead of booleans.
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Reusable templates ─────────────────────────────────────────────────────

model GeoTemplate {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  targets     Json // [{ country: "US", url: "https://..." }]

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([workspaceId])
}

model CampaignTemplate {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  source      String?
  medium      String?
  campaign    String?
  term        String?
  content     String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([workspaceId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

// ─── Custom Domains ──────────────────────────────────────────────────────────

enum DomainStatus {
  PENDING
  VERIFIED
  FAILED
}

model CustomDomain {
  id          String       @id @default(cuid())
  userId      String
  workspaceId String
  domain      String       @unique
  status      DomainStatus @default(PENDING)
  verifiedAt  DateTime?
  lastChecked DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links     Link[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([workspaceId])
  @@index([domain])
}

// ─── Link enums ─────────────────────────────────────────────────────────────

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  BOT
  UNKNOWN
}

// ─── Campaigns ──────────────────────────────────────────────────────────────

model Campaign {
  id          String  @id @default(cuid())
  userId      String
  workspaceId String
  name        String
  description String?
  shareToken  String? @unique

  // Scheduled report emails
  reportEmailEnabled    Boolean  @default(false)
  reportEmailFrequency  String?  // "weekly" | "monthly"
  reportEmailRecipients String[]
  reportEmailLastSentAt DateTime?

  links          Link[]
  clientAccesses ClientCampaignAccess[]

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([workspaceId])
}

// ─── Managed Links ──────────────────────────────────────────────────────────

model Link {
  id             String  @id @default(cuid())
  userId         String
  workspaceId    String
  campaignId     String?
  customDomainId String?
  title          String?

  originalUrl String
  shortCode   String  @unique

  passwordHash        String?
  isPasswordProtected Boolean @default(false)

  expiresAt   DateTime?
  maxClicks   Int?
  notes       String?
  tags        String[]
  isActive    Boolean   @default(true)
  geoTargets  Json?     // [{ country: "US", url: "https://..." }]
  abVariants        Json?     // [{ url: "https://...", weight: 50 }] — weights must sum to 100
  retargetingPixels Json?     // [{ type: "meta"|"google"|"tiktok"|"linkedin", id: "..." }]
  isFavorite        Boolean   @default(false)
  isCloaked         Boolean   @default(false)
  hideReferrer      Boolean   @default(false)
  redirectType      String    @default("302")  // "301" | "302" | "307"
  ogTitle           String?
  ogDescription     String?
  ogImage           String?

  qrFgColor  String  @default("#000000")
  qrBgColor  String  @default("#ffffff")
  qrEcLevel  String  @default("M")
  qrMargin   Int     @default(2)
  qrLogoUrl  String?

  clicks LinkClickEvent[]

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign     Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  customDomain CustomDomain? @relation(fields: [customDomainId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([workspaceId])
  @@index([campaignId])
  @@index([customDomainId])
  @@index([shortCode])
  @@index([createdAt])
}

model LinkClickEvent {
  id     String @id @default(cuid())
  linkId String

  ipHash    String?
  country   String?
  city      String?
  device    DeviceType @default(UNKNOWN)
  browser   String?
  os        String?
  referrer  String?
  userAgent String?

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([linkId])
  @@index([linkId, ipHash, createdAt])
  @@index([createdAt])
  @@index([device])
  @@index([country])
  @@index([utmSource])
  @@index([utmMedium])
  @@index([utmCampaign])
}

// ─── Client Portal ──────────────────────────────────────────────────────────

model ClientAccess {
  id          String  @id @default(cuid())
  token       String  @unique
  clientName  String?
  clientEmail String

  createdByUserId String
  workspaceId     String

  createdBy  User      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns  ClientCampaignAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([createdByUserId])
  @@index([workspaceId])
}

model ClientCampaignAccess {
  id             String @id @default(cuid())
  clientAccessId String
  campaignId     String

  clientAccess ClientAccess @relation(fields: [clientAccessId], references: [id], onDelete: Cascade)
  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([clientAccessId, campaignId])
  @@index([clientAccessId])
  @@index([campaignId])
}

// ─── Guest Links ─────────────────────────────────────────────────────────────

model GuestLink {
  id String @id @default(cuid())

  originalUrl String
  shortCode   String @unique

  passwordHash        String?
  isPasswordProtected Boolean @default(false)

  expiresAt   DateTime
  deleteAfter DateTime

  isActive Boolean @default(true)

  creatorIpHash    String?
  creatorUserAgent String?

  clicks GuestClickEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shortCode])
  @@index([expiresAt])
  @@index([deleteAfter])
  @@index([creatorIpHash])
  @@index([createdAt])
}

model GuestClickEvent {
  id String @id @default(cuid())

  guestLinkId String

  ipHash    String?
  country   String?
  city      String?
  device    DeviceType @default(UNKNOWN)
  browser   String?
  os        String?
  referrer  String?
  userAgent String?

  guestLink GuestLink @relation(fields: [guestLinkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([guestLinkId])
  @@index([guestLinkId, ipHash, createdAt])
  @@index([createdAt])
  @@index([ipHash])
  @@index([device])
  @@index([country])
}
